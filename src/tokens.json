      "secondary": "#3B82C4"
    },
    "dark": {
      "bg": {
        "base": "#0D1018",
        "surface": "#141923",
        "elevated": "#1C2333"
      },
      "text": {
        "display": "#FFFFFF",
        "primary": "#EDE9E4",
        "secondary": "#9CA3AF"
      },
      "border": {
        "default": "#252D3D",
        "subtle": "#1A2030"
      }
    },
    "light": {
